# ============================================
# 谛观 GreenwashGuard - 环境变量配置
# 复制为 .env 并填入实际值
# ============================================

# 应用模式: mock / real
APP_MODE=mock

# 数据库: sqlite（默认） / postgresql（生产环境推荐）
# SQLite 示例:
DATABASE_URL=sqlite:///./data/db/greenwash_guard.db
# PostgreSQL 示例（取消注释并填入实际值）:
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/greenwash_guard
# DB_POOL_SIZE=10
# DB_MAX_OVERFLOW=20

# API 配置
API_HOST=0.0.0.0
API_PORT=8000

# ---- LLM API Keys (真实模式) ----
# 模型一：DeepSeek-R1
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-reasoner

# 模型二：Qwen-3（通义千问）
QWEN_API_KEY=your_qwen_api_key
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-max

# 模型三：智谱 GLM（通用对话模型）
GLM_API_KEY=your_glm_api_key
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
GLM_MODEL=glm-4.7

# 前端地址（CORS）
FRONTEND_URL=http://localhost:5173

# 日志级别
LOG_LEVEL=INFO

# ---- MD&A 本地文本目录 ----
# 默认指向 backend/data/mda（相对路径），将MD&A数据放在此目录即可离线使用
# 也可填写绝对路径（如 E:\path\to\CMDA_ALL）
# 目录结构: MDA_ROOT/年份/文本/股票代码_公司名称_日期.txt
# 留空则不读取本地文件，依赖巨潮资讯爬虫或用户上传PDF
MDA_ROOT=data/mda
